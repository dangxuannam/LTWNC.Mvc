@{
    ViewBag.Title = "Xác nhận quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .confirmation-wrapper {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
    }

    .confirmation-container {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        max-width: 500px;
        width: 100%;
        overflow: hidden;
        text-align: center;
    }

    .confirmation-header {
        background: #17a2b8;
        padding: 50px 30px;
        text-align: center;
        color: white;
    }

    .confirmation-icon {
        width: 90px;
        height: 90px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 42px;
    }

    .confirmation-header h1 {
        font-size: 28px;
        font-weight: 600;
        margin: 0 0 8px 0;
    }

    .confirmation-header p {
        font-size: 14px;
        opacity: 0.9;
        margin: 0;
    }

    .confirmation-body {
        padding: 40px 35px;
    }

    .info-box {
        background: #e7f7fa;
        border-left: 4px solid #17a2b8;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 28px;
        text-align: left;
    }

        .info-box h3 {
            font-size: 15px;
            color: #0c5460;
            margin: 0 0 8px 0;
            font-weight: 600;
        }

        .info-box p {
            font-size: 13px;
            color: #0c5460;
            margin: 0;
            line-height: 1.6;
        }

    .btn-container {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .btn-primary {
        width: 100%;
        padding: 13px;
        background: #17a2b8;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-primary:hover {
            background: #138496;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
            color: white;
            text-decoration: none;
        }

    .btn-secondary {
        width: 100%;
        padding: 13px;
        background: white;
        color: #17a2b8;
        border: 2px solid #17a2b8;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .btn-secondary:hover {
            background: #e7f7fa;
            color: #17a2b8;
            text-decoration: none;
        }

    @@media (max-width: 576px) {
        .confirmation-wrapper {
            padding: 0;
        }

        .confirmation-container {
            border-radius: 0;
            min-height: calc(100vh - 60px);
        }

        .confirmation-body {
            padding: 35px 28px;
        }

        .confirmation-header {
            padding: 40px 28px;
        }
    }
</style>

<div class="confirmation-wrapper">
    <div class="confirmation-container">
        <div class="confirmation-header">
            <div class="confirmation-icon">✉️</div>
            <h1>Email không tồn tại</h1>
            <p>Không tìm thấy tài khoản với email này</p>
        </div>

        <div class="confirmation-body">
            <div class="info-box">
                <h3>⚠ Lưu ý</h3>
                <p>
                    Địa chỉ email bạn nhập không tồn tại trong hệ thống hoặc chưa được đăng ký.
                    Vui lòng kiểm tra lại email hoặc tạo tài khoản mới.
                </p>
            </div>

            <div class="btn-container">
                @Html.ActionLink("Thử lại", "ForgotPassword", "Account", null, new { @class = "btn-primary" })
                @Html.ActionLink("Tạo tài khoản mới", "Register", "Account", null, new { @class = "btn-secondary" })
            </div>
        </div>
    </div>
</div>
