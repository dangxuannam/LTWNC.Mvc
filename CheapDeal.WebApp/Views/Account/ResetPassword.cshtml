@model CheapDeal.WebApp.Models.ResetPasswordViewModel
@{
    ViewBag.Title = "Đặt mật khẩu mới";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .reset-wrapper {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
    }

    .reset-container {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
        max-width: 450px;
        width: 100%;
        overflow: hidden;
    }

    .reset-header {
        background: #17a2b8;
        padding: 40px 30px;
        text-align: center;
        color: white;
    }

    .reset-icon {
        width: 70px;
        height: 70px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 32px;
    }

    .reset-header h1 {
        font-size: 26px;
        font-weight: 600;
        margin: 0 0 8px 0;
    }

    .reset-header p {
        font-size: 14px;
        opacity: 0.9;
        margin: 0;
    }

    .reset-body {
        padding: 35px 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 8px;
        }

    .input-wrap {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #7f8c8d;
        font-size: 16px;
    }

    .form-control {
        width: 100%;
        padding: 12px 14px 12px 40px;
        border: 1px solid #dce4ec;
        border-radius: 8px;
        font-size: 14px;
        transition: all 0.3s ease;
        background: #f8f9fa;
        box-sizing: border-box;
    }

        .form-control:focus {
            outline: none;
            border-color: #17a2b8;
            background: white;
            box-shadow: 0 0 0 3px rgba(23, 162, 184, 0.1);
        }

    .text-danger {
        color: #e74c3c;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }

    .btn-submit {
        width: 100%;
        padding: 13px;
        background: #17a2b8;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 8px;
    }

        .btn-submit:hover {
            background: #138496;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
        }
</style>

<div class="reset-wrapper">
    <div class="reset-container">
        <div class="reset-header">
            <div class="reset-icon">🔑</div>
            <h1>Đặt mật khẩu mới</h1>
            <p>Nhập mật khẩu mới cho tài khoản của bạn</p>
        </div>

        <div class="reset-body">
            @using (Html.BeginForm("ResetPassword", "Account", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="form-group">
                    <label>Mật khẩu mới <span style="color:#e74c3c">*</span></label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        @Html.PasswordFor(m => m.Password, new
                        {
                            @class = "form-control",
                            placeholder = "Nhập mật khẩu mới (ít nhất 6 ký tự)"
                        })
                    </div>
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label>Xác nhận mật khẩu <span style="color:#e74c3c">*</span></label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        @Html.PasswordFor(m => m.ConfirmPassword, new
                        {
                            @class = "form-control",
                            placeholder = "Nhập lại mật khẩu mới"
                        })
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn-submit">💾 Lưu mật khẩu mới</button>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
