@model CheapDeal.WebApp.Models.ChangePasswordWithOtpViewModel
@{
    ViewBag.Title = "Đổi mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .cp-wrapper {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: linear-gradient(135deg, #17a2b8 0%, #20c997 100%);
    }

    .cp-container {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.15);
        max-width: 480px;
        width: 100%;
        overflow: hidden;
    }

    .cp-header {
        background: #20c997;
        padding: 36px 30px;
        text-align: center;
        color: white;
    }

    .cp-icon {
        width: 70px;
        height: 70px;
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 32px;
    }

    .cp-header h1 {
        font-size: 26px;
        font-weight: 600;
        margin: 0 0 6px;
    }

    .cp-header p {
        font-size: 13px;
        opacity: 0.9;
        margin: 0;
    }

    .cp-body {
        padding: 32px 30px;
    }

    .step-label {
        font-size: 13px;
        font-weight: 700;
        color: #17a2b8;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .step-badge {
        background: #17a2b8;
        color: white;
        border-radius: 50%;
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: bold;
        flex-shrink: 0;
    }

        .step-badge.green {
            background: #20c997;
        }

    .form-group {
        margin-bottom: 18px;
    }

        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: #2c3e50;
            margin-bottom: 6px;
        }

    .required {
        color: #e74c3c;
    }

    .input-wrap {
        position: relative;
    }

    .input-icon {
        position: absolute;
        left: 13px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 15px;
        color: #7f8c8d;
    }

    .form-control {
        width: 100%;
        padding: 11px 13px 11px 38px;
        border: 1px solid #dce4ec;
        border-radius: 8px;
        font-size: 14px;
        background: #f8f9fa;
        transition: all 0.3s;
        box-sizing: border-box;
    }

        .form-control:focus {
            outline: none;
            border-color: #20c997;
            background: white;
            box-shadow: 0 0 0 3px rgba(32,201,151,0.1);
        }

    .otp-row {
        display: flex;
        gap: 10px;
        align-items: flex-end;
    }

        .otp-row .form-group {
            flex: 1;
            margin-bottom: 0;
        }

    .btn-send-otp {
        padding: 11px 16px;
        background: #17a2b8;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: all 0.3s;
        flex-shrink: 0;
    }

        .btn-send-otp:hover {
            background: #138496;
        }

        .btn-send-otp:disabled {
            background: #95a5a6;
            cursor: not-allowed;
        }

    .otp-status {
        font-size: 12px;
        margin-top: 6px;
        display: none;
    }

        .otp-status.success {
            color: #17a2b8;
        }

        .otp-status.error {
            color: #e74c3c;
        }

        .otp-status.timer {
            color: #e74c3c;
            font-weight: bold;
        }

    .text-danger {
        color: #e74c3c;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    .divider {
        border: none;
        border-top: 1px solid #e1e8ed;
        margin: 24px 0;
    }

    .btn-submit {
        width: 100%;
        padding: 13px;
        background: #20c997;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
    }

        .btn-submit:hover {
            background: #1ab386;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(32,201,151,0.3);
        }

    .back-link {
        text-align: center;
        margin-top: 16px;
    }

        .back-link a {
            color: #17a2b8;
            font-size: 13px;
            text-decoration: none;
        }

            .back-link a:hover {
                text-decoration: underline;
            }

    @@media (max-width: 576px) {
        .cp-wrapper {
            padding: 0;
        }

        .cp-container {
            border-radius: 0;
            min-height: calc(100vh - 60px);
        }

        .cp-body {
            padding: 28px 22px;
        }
    }
</style>

<div class="cp-wrapper">
    <div class="cp-container">
        <div class="cp-header">
            <div class="cp-icon">🔑</div>
            <h1>Đổi mật khẩu</h1>
            <p>Xác thực OTP qua email trước khi đổi mật khẩu</p>
        </div>

        <div class="cp-body">

            @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { role = "form", id = "changePassForm" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <!-- BƯỚC 1: GỬI OTP -->
                <div class="step-label">
                    <span class="step-badge">1</span> Xác thực qua email
                </div>

                <div class="otp-row">
                    <div class="form-group">
                        <label>Mã OTP <span class="required">*</span></label>
                        <div class="input-wrap">
                            <span class="input-icon">🔢</span>
                            @Html.TextBoxFor(m => m.Otp, new
                            {
                                @class = "form-control",
                                placeholder = "Nhập mã 6 số",
                                maxlength = "6",
                                inputmode = "numeric",
                                autocomplete = "one-time-code",
                                id = "otpInput"
                            })
                        </div>
                        @Html.ValidationMessageFor(m => m.Otp, "", new { @class = "text-danger" })
                    </div>
                    <button type="button" class="btn-send-otp" id="btnSendOtp" onclick="sendOtp()">
                        📧 Gửi OTP
                    </button>
                </div>
                <div class="otp-status" id="otpStatus"></div>

                <hr class="divider" />

                <!-- BƯỚC 2: MẬT KHẨU MỚI -->
                <div class="step-label">
                    <span class="step-badge green">2</span> Mật khẩu mới
                </div>

                <div class="form-group">
                    <label>Mật khẩu mới <span class="required">*</span></label>
                    <div class="input-wrap">
                        <span class="input-icon">🔒</span>
                        @Html.PasswordFor(m => m.NewPassword, new
                        {
                            @class = "form-control",
                            placeholder = "Ít nhất 6 ký tự",
                            id = "newPassword"
                        })
                    </div>
                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger" })
                </div>

                <div class="form-group">
                    <label>Xác nhận mật khẩu <span class="required">*</span></label>
                    <div class="input-wrap">
                        <span class="input-icon">✓</span>
                        @Html.PasswordFor(m => m.ConfirmPassword, new
                        {
                            @class = "form-control",
                            placeholder = "Nhập lại mật khẩu mới"
                        })
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn-submit">
                    ✓ Xác nhận đổi mật khẩu
                </button>
            }

            <div class="back-link">
                @Html.ActionLink("⟵ Quay lại trang quản lý", "Index", "Manage")
            </div>
        </div>
    </div>
</div>

<script>
    var otpTimer = null;

    // Chỉ nhập số trong ô OTP
    document.getElementById('otpInput').addEventListener('input', function () {
        this.value = this.value.replace(/[^0-9]/g, '');
    });

    function setStatus(type, msg) {
        var el = document.getElementById('otpStatus');
        el.className = 'otp-status ' + type;
        el.textContent = msg;
        el.style.display = 'block';
    }

    function sendOtp() {
        var btn = document.getElementById('btnSendOtp');
        btn.disabled = true;
        btn.textContent = 'Đang gửi...';

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('@Url.Action("SendChangePasswordOtp", "Manage")', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: '__RequestVerificationToken=' + encodeURIComponent(token)
        })
        .then(function (r) { return r.json(); })
        .then(function (data) {
            if (data.success) {
                setStatus('success', '✓ ' + data.message);
                startTimer(btn);
            } else {
                setStatus('error', '✗ ' + data.message);
                btn.disabled = false;
                btn.textContent = '📧 Gửi OTP';
            }
        })
        .catch(function () {
            setStatus('error', 'Lỗi kết nối. Vui lòng thử lại.');
            btn.disabled = false;
            btn.textContent = '📧 Gửi OTP';
        });
    }

    function startTimer(btn) {
        var t = 600; // 10 phút
        if (otpTimer) clearInterval(otpTimer);

        otpTimer = setInterval(function () {
            t--;
            var m = Math.floor(t / 60), s = t % 60;
            setStatus('timer', 'Mã hết hạn sau: ' + m + ':' + (s < 10 ? '0' : '') + s);

            if (t <= 0) {
                clearInterval(otpTimer);
                setStatus('error', 'Mã OTP đã hết hạn. Vui lòng gửi lại.');
                btn.disabled = false;
                btn.textContent = '🔄 Gửi lại OTP';
            }
        }, 1000);

        // Cho phép gửi lại sau 60 giây
        setTimeout(function () {
            btn.disabled = false;
            btn.textContent = '🔄 Gửi lại OTP';
        }, 60000);
    }
</script>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
