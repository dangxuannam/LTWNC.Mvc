@model IEnumerable<CheapDeal.WebApp.Models.Reminder>
@{
    ViewBag.Title = "Reminders";
    Layout = "~/Areas/Adm/Views/Shared/_Layout.cshtml";
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-10">
        <h2>Danh Sách Reminders</h2>
        <ol class="breadcrumb">
            <li><a href="/">Trang chủ</a></li>
            <li><a href="@Url.Action("Index", "Job", new { area = "Adm" })">Background Jobs</a></li>
            <li class="active">Reminders</li>
        </ol>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5><i class="fa fa-bell"></i> Reminders (@Model.Count() bản ghi)</h5>
                </div>
                <div class="ibox-content">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Schedule ID</th>
                                <th>Ngày nhắc</th>
                                <th>Status</th>
                                <th>Subject</th>
                                <th>Ngày tạo</th>
                                <th>Ngày gửi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        Chưa có reminder nào. Chạy Scan Reminders để tạo.
                                    </td>
                                </tr>
                            }
                            @foreach (var r in Model)
                            {
                                <tr>
                                    <td>@r.ReminderId</td>
                                    <td>@r.ScheduleId</td>
                                    <td>@r.ReminderDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="label label-@(r.Status == "SENT" ? "primary" : "warning")">
                                            @r.Status
                                        </span>
                                    </td>
                                    <td><small>@r.Subject</small></td>
                                    <td>@r.CreatedDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(r.SentDate.HasValue ? r.SentDate.Value.ToString("dd/MM HH:mm") : "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>