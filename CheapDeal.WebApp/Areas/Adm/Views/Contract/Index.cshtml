@model IEnumerable<CheapDeal.WebApp.Models.Contract>

@{
    ViewBag.Title = "Quản lý hợp đồng";
    Layout = "~/Areas/Adm/Views/Shared/_Layout.cshtml";
}

<div class="row wrapper border-bottom white-bg page-heading">
    <div class="col-lg-10">
        <h2>Quản lý hợp đồng</h2>
        <ol class="breadcrumb">
            <li><a href="@Url.Action("Index", "Dashboard", new { area = "Adm" })">Trang chủ</a></li>
            <li class="active"><strong>Hợp đồng</strong></li>
        </ol>
    </div>
    <div class="col-lg-2">
        <div class="title-action">
            <a href="@Url.Action("ImportExcel", "Contract", new { area = "Adm" })"
               class="btn btn-primary" style="margin-top:30px">
                <i class="fa fa-upload"></i> Import Excel
            </a>
        </div>
    </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>Danh sách hợp đồng (Tổng: <strong>@ViewBag.TotalContracts</strong>)</h5>
                    <div class="ibox-tools">
                        <a href="@Url.Action("ExportExcel", "Contract", new { area = "Adm", search = ViewBag.Search, status = ViewBag.CurrentStatus })"
                           class="btn btn-sm btn-success" title="Xuất danh sách ra file Excel">
                            <i class="fa fa-file-excel-o"></i> Xuất Excel
                        </a>
                        <a class="collapse-link"><i class="fa fa-chevron-up"></i></a>
                    </div>
                </div>
                <div class="ibox-content">

                    @{ var filterForm = Html.BeginForm("Index", "Contract",
                            new { area = "Adm" }, FormMethod.Get,
                            new { @class = "form-horizontal" }); }
                    <div class="form-group">
                        <div class="col-sm-3">
                            <input type="text" name="search" value="@ViewBag.Search"
                                   class="form-control" placeholder="Tìm mã HĐ, email khách hàng..." />
                        </div>
                        <div class="col-sm-3">
                            <select name="status" class="form-control">
                                <option value="">-- Tất cả trạng thái --</option>
                                @if (ViewBag.StatusList != null)
                                {
                                    foreach (var s in ViewBag.StatusList)
                                    {
                                        <option value="@s.StatusCode"
                                                @(ViewBag.CurrentStatus == s.StatusCode ? "selected" : "")>
                                            @s.StatusName
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-sm-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-search"></i> Tìm kiếm
                            </button>
                            <a href="@Url.Action("Index", "Contract", new { area = "Adm" })"
                               class="btn btn-white">
                                <i class="fa fa-refresh"></i> Làm mới
                            </a>
                            <a href="@Url.Action("DownloadTemplate", "Contract", new { area = "Adm" })"
                               class="btn btn-default">
                                <i class="fa fa-download"></i> File mẫu
                            </a>
                        </div>
                    </div>
                    @{ filterForm.Dispose(); }

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Mã HĐ</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày ký</th>
                                    <th>Hiệu lực</th>
                                    <th class="text-right">Tổng tiền</th>
                                    <th class="text-right">Đã thanh toán</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-center" style="width:80px">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        var paidPct = item.TotalAmount > 0
                                            ? (int)(item.PaidAmount / item.TotalAmount * 100) : 0;
                                        <tr>
                                            <td>
                                                <strong>@item.ContractCode</strong>
                                                @if (!string.IsNullOrEmpty(item.DocumentPath))
                                                {
                                                    <br />
                                                    <small>
                                                        <i class="fa fa-file-pdf-o text-danger"></i>
                                                        <a href="@Url.Content(item.DocumentPath)"
                                                           target="_blank" class="text-muted">PDF</a>
                                                    </small>
                                                }
                                            </td>
                                            <td>
                                                @if (item.Customer != null)
                                                {
                                                    <span>@item.Customer.UserName</span>
                                                    <br />
                                                    <small class="text-muted">@item.Customer.Email</small>
                                                }
                                            </td>
                                            <td>@item.ContractDate.ToString("dd/MM/yyyy")</td>
                                            <td>
                                                <small>
                                                    @item.StartDate.ToString("dd/MM/yyyy")
                                                    <i class="fa fa-arrow-right text-muted"></i>
                                                    @item.EndDate.ToString("dd/MM/yyyy")
                                                </small>
                                            </td>
                                            <td class="text-right">
                                                <strong class="text-navy">
                                                    @item.TotalAmount.ToString("N0") đ
                                                </strong>
                                            </td>
                                            <td class="text-right">
                                                <small class="@(paidPct >= 100 ? "text-navy" : "text-muted")">
                                                    @item.PaidAmount.ToString("N0") đ
                                                </small>
                                                <div class="progress" style="height:4px;margin:3px 0 0">
                                                    <div class="progress-bar @(paidPct >= 100 ? "progress-bar-success" : "progress-bar-warning")"
                                                         style="width:@(paidPct)%"></div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                @if (item.Status != null)
                                                {
                                                    <span class="label"
                                                          style="background:@(item.Status.Color ?? "#6c757d");color:#fff;padding:4px 8px">
                                                        @item.Status.StatusName
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <a href="@Url.Action("Detail", "Contract",
                                                       new { area = "Adm", id = item.ContractId })"
                                                   class="btn btn-white btn-sm" title="Xem chi tiết">
                                                    <i class="fa fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center">
                                            <p class="text-muted" style="padding:30px 0">
                                                <i class="fa fa-inbox fa-2x"></i><br />
                                                Chưa có hợp đồng nào
                                            </p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (ViewBag.TotalPages > 1)
                    {
                        <div class="text-center">
                            <ul class="pagination">
                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="@(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a href="@Url.Action("Index", "Contract", new {
                                               area   = "Adm",
                                               page   = i,
                                               search = ViewBag.Search,
                                               status = ViewBag.CurrentStatus
                                           })">@i</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
$(document).ready(function () {
    @if (TempData["SuccessMessage"] != null) { <text>toastr.success('@TempData["SuccessMessage"]');</text> }
    @if (TempData["ErrorMessage"]   != null) { <text>toastr.error('@TempData["ErrorMessage"]');</text>   }
});
    </script>
}
