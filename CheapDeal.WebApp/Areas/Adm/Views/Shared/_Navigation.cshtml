<style>
    /* ── Sidebar ─────────────────────────────────────────── */
    #side-menu {
        width: 100%;
        list-style: none;
        padding: 0;
        margin: 0;
    }

        /* Top-level */
        #side-menu > li {
            border-bottom: 1px solid #293846;
        }

            #side-menu > li > a {
                color: #a7b1c2;
                padding: 14px 20px;
                display: block;
                text-decoration: none;
                border-left: 4px solid transparent;
                transition: all 0.25s;
                position: relative;
            }

                #side-menu > li > a i {
                    margin-right: 10px;
                    width: 20px;
                    text-align: center;
                }

                #side-menu > li > a .arrow {
                    position: absolute;
                    right: 20px;
                    top: 50%;
                    transform: translateY(-50%);
                    font-size: 12px;
                    color: #a7b1c2;
                    transition: transform 0.25s, color 0.25s;
                }

                #side-menu > li > a:hover,
                #side-menu > li.active > a {
                    color: #fff;
                    background: #293846;
                    border-left-color: #19aa8d;
                }

                    #side-menu > li:hover > a .arrow,
                    #side-menu > li.active > a .arrow {
                        transform: translateY(-50%) rotate(90deg);
                        color: #19aa8d;
                    }

    /* Submenu */
    .nav-second-level {
        background: #1c2b36;
        list-style: none;
        padding: 0;
        margin: 0;
        display: none;
        max-height: 400px;
        overflow-y: auto;
    }

    #side-menu > li:hover > .nav-second-level {
        display: block;
    }

    .nav-second-level li {
        border-top: 1px solid #253444;
    }

        .nav-second-level li:first-child {
            border-top: none;
        }

        .nav-second-level li a {
            color: #a7b1c2;
            padding: 10px 15px 10px 45px;
            display: block;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.2s;
            position: relative;
        }

            .nav-second-level li a::before {
                content: "›";
                position: absolute;
                left: 30px;
                color: #a7b1c2;
            }

            .nav-second-level li a:hover {
                color: #fff;
                background: #253444;
                padding-left: 50px;
            }

                .nav-second-level li a:hover::before {
                    color: #19aa8d;
                }

    /* Scrollbar */
    .nav-second-level::-webkit-scrollbar {
        width: 4px;
    }

    .nav-second-level::-webkit-scrollbar-thumb {
        background: #19aa8d;
        border-radius: 3px;
    }

    /* Badge */
    .nav-badge {
        font-size: 10px;
        padding: 2px 5px;
        border-radius: 8px;
        margin-left: 5px;
        font-weight: 600;
        vertical-align: middle;
        background: #19aa8d;
        color: #fff;
    }

        .nav-badge.new {
            background: #ed5565;
        }

        .nav-badge.soon {
            background: #6B7280;
        }
</style>

